# MongoDB Atlas connection string
MONGO_URI=

# JWT signing secret (use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=

# Google OAuth2 credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Gmail credentials for Nodemailer
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Ollama local LLM
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# CORS - frontend URL
FRONTEND_URL=http://localhost:3000

# CSRF / session
SESSION_SECRET=

# Environment
NODE_ENV=development

# Comma-separated admin email addresses
ADMIN_EMAILS=

# Server port
PORT=5000

# Google Gemini AI API Key (from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Google Custom Search Engine (optional)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Groq API Key (for testGroq.js - from https://console.groq.com/keys)
GROQ_API_KEY=
